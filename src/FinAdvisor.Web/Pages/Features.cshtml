@page "/features"
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Fitur";
}

<section class="card readable">
    <p class="eyebrow">Fitur FIN-ADVISOR</p>
    <h1>Semua yang dibutuhkan UMKM untuk membaca kesiapan pembiayaan.</h1>
    <div class="feature-grid">
        <div><h3>Konsultasi AI</h3><p>Analisis kondisi usaha menggunakan Forward Chaining berbasis aturan pakar.</p></div>
        <div><h3>Profil UMKM</h3><p>Simpan data usaha, pemilik, kontak, omzet, alamat, dan tujuan pembiayaan.</p></div>
        <div><h3>Riwayat Konsultasi</h3><p>Lihat kembali hasil rekomendasi dan bandingkan keputusan dari waktu ke waktu.</p></div>
        <div><h3>Explanation Facility</h3><p>Pahami rule aktif, fakta yang cocok, confidence, risiko, dan saran berikutnya.</p></div>
        <div><h3>Admin Rule</h3><p>Pengelola dapat menambah, mengubah, mengaktifkan, dan menonaktifkan aturan.</p></div>
        <div><h3>Dashboard Monitoring</h3><p>Admin dapat melihat total user, konsultasi, rule aktif, dan aktivitas terbaru.</p></div>
    </div>
</section>
