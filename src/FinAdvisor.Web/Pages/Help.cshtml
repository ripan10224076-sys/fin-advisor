@page
@model FinAdvisor.Web.Pages.HelpModel
@{
    ViewData["Title"] = "Bantuan";
}

<section class="card readable">
    <p class="eyebrow">Bantuan</p>
    <h1>Cara Menggunakan</h1>
    <div class="feature-grid">
        <div><h3>1. Isi kondisi usaha</h3><p>Pilih arus kas, agunan, nominal dana, riwayat kredit, legalitas, dan kebutuhan dana mendesak.</p></div>
        <div><h3>2. Klik analisis</h3><p>Sistem mengubah jawaban menjadi fakta dan menjalankan forward chaining terhadap rule aktif.</p></div>
        <div><h3>3. Baca rekomendasi</h3><p>Periksa jenis pembiayaan, skor, alasan, risiko, persyaratan, dan checklist dokumen.</p></div>
        <div><h3>4. Kelola riwayat</h3><p>Hasil otomatis masuk riwayat. Gunakan tombol print untuk menyimpan sebagai PDF.</p></div>
    </div>
</section>
