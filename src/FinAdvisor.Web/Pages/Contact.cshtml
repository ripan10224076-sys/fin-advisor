@page "/contact"
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Kontak";
}

<section class="workspace-grid">
    <div class="card readable">
        <p class="eyebrow">Kontak</p>
        <h1>Butuh bantuan menggunakan FIN-ADVISOR?</h1>
        <p>Hubungi pengelola sistem untuk bantuan akun, pengelolaan rule, atau pertanyaan tentang hasil rekomendasi.</p>
        <div class="profile-strip">
            <span>Email: support@finadvisor.local</span>
            <span>Jam layanan: Senin-Jumat</span>
            <span>Respons: 1x24 jam kerja</span>
        </div>
    </div>
    <aside class="info-panel">
        <h3>Tips sebelum menghubungi</h3>
        <ul>
            <li>Siapkan email akun UMKM.</li>
            <li>Catat rekomendasi yang ingin ditanyakan.</li>
            <li>Periksa kembali data profil usaha.</li>
        </ul>
    </aside>
</section>
