@page "/umkm/history"
@model FinAdvisor.Web.Pages.Umkm.HistoryModel
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Riwayat Konsultasi";
}

<section class="card">
    <div class="section-heading">
        <p class="eyebrow">Riwayat Konsultasi</p>
        <h1>Hasil yang Pernah Disimpan</h1>
    </div>
    <form method="get" class="toolbar">
        <input asp-for="Query" placeholder="Cari nama usaha atau rekomendasi" />
        <select asp-for="Recommendation">
            <option value="">Semua rekomendasi</option>
            @foreach (var option in Model.RecommendationOptions)
            {
                <option value="@option">@option</option>
            }
        </select>
        <button class="btn-primary" type="submit">Filter</button>
        <button class="btn-secondary" type="button" onclick="window.print()">Export PDF / Print</button>
    </form>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Tanggal</th><th>Usaha</th><th>Rekomendasi</th><th>Rule</th><th>Skor</th><th>Penjelasan</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@item.BusinessName</td>
                    <td><span class="badge">@item.Recommendation</span></td>
                    <td>@item.RuleCode</td>
                    <td>@item.Score</td>
                    <td>@item.Explanation</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
